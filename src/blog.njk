---
layout: layouts/home.njk
pagination:
  data: collections.posts
  size: 10 # posts per page
  reverse: true
  generatePageOnEmptyData: true
eleventyComputed:
  permalink: "{% set base = '/' if site.home.target == 'blog' else '/blog/' %}{% if pagination.pageNumber == 0 %}{{ base }}{% else %}{{ base }}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
  title: "{% if pagination.pageNumber == 0 %}{{ ui.pages.home.title }}{% else %}{{ ui.pages.home.title }} {{ ui.shared.pagination.separator }} {{ ui.shared.pagination.page }} {{ pagination.pageNumber + 1 }}{% endif %}"
---

{% from "components/post-list.njk" import renderPostList with context %}
{% set base = '/' if site.home.target == 'blog' else '/blog/' %}
{% set pageCount = pagination.pages | length %}
{% set hasPreviousPage = pagination.pageNumber > 0 %}
{% set hasNextPage = pagination.pageNumber + 1 < pageCount %}
{% set previousHref = null %}
{% set nextHref = null %}
{% if hasPreviousPage %}
  {% set previousHref = base if pagination.pageNumber == 1 else base ~ 'page/' ~ pagination.pageNumber ~ '/' %}
{% endif %}
{% if hasNextPage %}
  {% set nextHref = base ~ 'page/' ~ (pagination.pageNumber + 2) ~ '/' %}
{% endif %}

<section class="mw7 center">
  <h1 class="f3 f2-ns lh-title mt0 mb0">{{ ui.pages.home.heading }}</h1>
  {{ renderPostList(pagination.items, ui.pages.home.emptyMessage, false) | safe }}
  {% if pageCount > 1 %}
    <nav class="flex justify-between items-center f6 theme-midtone mt4">
      <div>
        {% if previousHref %}
          <a class="link dim theme-text" href="{{ previousHref }}">{{ ui.shared.pagination.previous }}</a>
        {% endif %}
      </div>
      <div>{{ ui.shared.pagination.page }} {{ pagination.pageNumber + 1 }} {{ ui.shared.pagination.of }} {{ pageCount }}</div>
      <div>
        {% if nextHref %}
          <a class="link dim theme-text" href="{{ nextHref }}">{{ ui.shared.pagination.next }}</a>
        {% endif %}
      </div>
    </nav>
  {% endif %}
</section>
