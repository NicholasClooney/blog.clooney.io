<script>
	(function() {
		const themeTarget = document.documentElement;
		const defaultThemeId = themeTarget.dataset.defaultTheme;
		const autoLightThemeId = themeTarget.dataset.autoLightTheme || defaultThemeId;
		const autoDarkThemeId = themeTarget.dataset.autoDarkTheme || defaultThemeId;
		const preferenceStorageKey = 'themePreference';
		const themeConfig = {{ themes | dump | safe }};
		const themeMap = themeConfig.reduce((map, theme) => {
			map[theme.id] = theme.classes;
			return map;
		}, {});
		const allThemeClasses = Array.from(new Set(themeConfig.flatMap(theme => theme.classes)));

		function getSystemThemeId() {
			if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
				return themeMap[autoDarkThemeId] ? autoDarkThemeId : defaultThemeId;
			}
			return themeMap[autoLightThemeId] ? autoLightThemeId : defaultThemeId;
		}

		function resolveThemeId(preference) {
			if (preference === 'auto') {
				return getSystemThemeId();
			}
			return themeMap[preference] ? preference : defaultThemeId;
		}

		let desiredPreference = themeTarget.dataset.themePreference || 'auto';
		try {
			const storedPreference = localStorage.getItem(preferenceStorageKey);
			if (storedPreference === 'auto' || themeMap[storedPreference]) {
				desiredPreference = storedPreference;
			} else {
				const storedTheme = localStorage.getItem('theme');
				if (storedTheme && themeMap[storedTheme]) {
					desiredPreference = storedTheme;
				}
			}
		} catch (error) {
			/* Ignore storage access errors and fall back to default theme. */
		}
		const desiredThemeId = resolveThemeId(desiredPreference);
		const desiredClasses = themeMap[desiredThemeId];
		if (!desiredClasses) return;
		themeTarget.classList.remove(...allThemeClasses);
		themeTarget.classList.add(...desiredClasses);
		themeTarget.dataset.theme = desiredThemeId;
		themeTarget.dataset.themePreference = desiredPreference;
	})();
</script>
